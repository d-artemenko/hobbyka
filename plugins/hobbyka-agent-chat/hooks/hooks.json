{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/sh \"$PLUGIN_ROOT/hooks/run.sh\" session-start",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$env:PLUGIN_ROOT\\hooks\\run.ps1\" session-start",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/sh \"$PLUGIN_ROOT/hooks/run.sh\" post-tool-use",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$env:PLUGIN_ROOT\\hooks\\run.ps1\" post-tool-use",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
